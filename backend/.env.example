# Astraeus backend environment variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.

# NASA Open APIs — get a free key at https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# DuckDB file path (use forward slashes on Windows)
# Docker: /data/astraeus.duckdb  (mounted from persistent volume)
# Local:  /absolute/path/to/astraeus.duckdb
DB_PATH=/data/astraeus.duckdb

# Address to bind the HTTP server
BIND_ADDR=0.0.0.0:3000

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info

# ML inference service base URL
# Docker:  http://ml:8000   (Docker service name)
# Local:   http://localhost:8000
ML_SERVICE_URL=http://ml:8000

# JWT signing secret — generate with: openssl rand -hex 32
# Must be at least 32 characters; 64-char hex recommended
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Resend email delivery — get a key at https://resend.com/
RESEND_API_KEY=re_YOUR_API_KEY_HERE
# From address — use onboarding@resend.dev until your domain is verified in Resend
RESEND_FROM=Astraeus <onboarding@resend.dev>
